---
// ProfileCard.astro - Main profile card component
---

<div class="col-span-3 row-span-2 md:row-span-4 bg-[#af72ff56] rounded-3xl p-5 sm:p-6 text-white relative overflow-hidden group">
  <div class="absolute inset-0 bg-black/20"></div>

  <!-- Animated Background Wave (Bottom half only) -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="wave-clipper">
      <div class="wave-container">
        <div class="wave"></div>
      </div>
    </div>
  </div>

  <div class="relative z-10 h-full flex flex-col md:flex-row items-start md:items-end gap-4 md:gap-8">
    <div class="w-full md:w-8/12 flex flex-col justify-center md:justify-end h-full">
      <h1 class="text-2xl sm:text-4xl md:text-5xl lg:text-4.5xl font-extrabold mb-2 sm:mb-4 flex items-center gap-2">
        <span data-text="greeting"> 👋 Hi, I'm <br class="block sm:hidden" /> Caleb Condor Carrera</span>
      </h1>
      <p class="text-xs sm:text-lg md:text-xl lg:text-xl text-purple-100 leading-relaxed mb-4" data-text="description">
        I am a frontend developer specializing in React and Next.js. I love building amazing UI experiences. I have been working professionally for +6 months and have worked on several projects.
      </p>
      <div class="flex items-center gap-2 text-purple-200 text-xs sm:text-sm md:text-base">
        <svg class="w-3 h-3 sm:w-4 sm:h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
        </svg>
        <span>Remote Work</span>
      </div>
    </div>
    <img
      src="/Kenny.png"
      alt="Cartman"
      class="absolute -bottom-8 -right-1/4 w-8/12 md:h-full md:auto object-cover -z-0 hidden md:flex"
    />
  </div>
</div>

<style>
  .wave-container {
    position: absolute;
    width: 250%;
    height: 100%;
    bottom: -50%; /* Mantenemos la ola abajo */
    left: -75%;
    z-index: 1;
    opacity: 0.6;
    pointer-events: none;
  }

 .wave {
  position: absolute;
  width: 100%;
  height: 100%;
  background: #2d0a4e4a;
  border-radius: 45% 55% 60% 40% / 60% 60% 40% 40%;
  animation: wave-animation 10s infinite ease-in-out;
}

@keyframes wave-animation {
  0% {
    transform: translateX(0) translateY(0) rotate(0deg);
  }
  25% {
    transform: translateX(-10%) translateY(-6px) rotate(2deg);
  }
  50% {
    transform: translateX(-20%) translateY(-12px) rotate(4deg);
  }
  75% {
    transform: translateX(-10%) translateY(-6px) rotate(2deg);
  }
  100% {
    transform: translateX(0) translateY(0) rotate(0deg);
  }
}
  /* Contenedor que recorta la ola para que NUNCA suba de la mitad */
  .wave-clipper {
    position: absolute;
    inset: 0;
    overflow: hidden;
    /* Este clip-path asegura que las olas solo existan en el 50% inferior */
  }



  @media (max-width: 768px) {
    .wave-clipper {
    }
  }
</style> 
---
import Layout from '../layouts/Layout.astro';
import ProfileCard from '../components/ProfileCard.astro';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import DiscordStatus from '../components/DiscordStatus.astro';
import SocialCard from '../components/SocialCard.astro';
import { 
  Github, 
  Linkedin, 
  Mail, 
  MapPin, 
  Calendar, 
  Code, 
  Trophy, 
  Users, 
  Star,
  Twitter,
  ExternalLink,
  Globe,
  Sun
} from 'lucide-astro';
import "../style.css"
---


<Layout title="Caleb Condor Carrera - Frontend Developer">
  <div class="min-h-screen bg-gradient-to-br from-slate-900 via-purple-900 to-slate-900 p-4 cartman-bg">
    <div class="xl:max-w-[75vw] mx-auto">      
      <!-- Language Selector -->


      <!-- Grid Layout -->
      <div class="grid grid-cols-4 grid-rows-12 gap-3 xl:h-[1600px]">
        <!-- 1 - Main Profile Card -->
        <ProfileCard />

        <!-- 2 - Language Switcher -->
        <LanguageSwitcher />

        <!-- 3 - LinkedIn -->
        <SocialCard platform="linkedin" position="col-start-4 row-start-3" />

        <!-- 4 - Projects Count -->
        <div class="row-span-2 row-start-5 bg-gradient-to-br from-orange-500 to-orange-600 rounded-3xl p-4 text-white flex flex-col justify-center items-center select-none">
          <div class="text-2xl font-extrabold text-white mb-2 transition-all duration-200 " id="">AGE</div>
          <div class="text-6xl font-extrabold text-white mb-2 transition-all duration-200" id="age-value">20</div>
          <div id="age-label" class="text-2xl font-bold text-white/80">years</div>
        </div>

        <!-- 9 - GitHub -->
        <div class="row-span-2 row-start-5 bg-gradient-to-br from-slate-700 to-slate-800 rounded-3xl p-4 text-white relative overflow-hidden group hover:scale-[1.02] transition-transform duration-300">
          <div class="absolute top-3 right-3">
            <Github class="w-5 h-5 text-slate-400" />
          </div>
          <div class="h-full flex flex-col justify-between">
            <div>
              <div class="text-xs text-slate-400 mb-1">GitHub</div>
              <div class="text-xs text-slate-500" data-text="githubText">My projects</div>
            </div>
            <div class="flex items-center gap-2 text-slate-400">
              <div class="w-6 h-6 rounded-full bg-amber-500 flex items-center justify-center">
                <span class="text-xs font-bold text-white">OM</span>
              </div>
              <span class="text-xs">@orlando-mina</span>
            </div>
          </div>
        </div>

        <!-- 10 - Projects Description -->
        <div class="col-span-2 row-span-2 row-start-5 bg-[url('/cartman_paz.gif')] bg-cover bg-center bg-no-repeat bg-slate-800/90 backdrop-blur-sm rounded-3xl p-4 text-white border border-slate-700/50 group hover:scale-[1.02] transition-transform duration-300">
          <h3 class="text-base font-semibold mb-2 text-purple-300" data-text="projectsTitle">Projects and tests</h3>
          <p class="text-slate-300 text-sm leading-relaxed mb-3" data-text="projectsDesc">
            Here you can find some of my projects, both professional and personal.
          </p>
          <div class="flex items-center gap-2 text-purple-400">
            <ExternalLink class="w-4 h-4" />
            <span class="text-xs">View Portfolio</span>
          </div>
        </div>

        <!-- 11 - Skills -->
        <div class="col-span-2 row-span-2 row-start-7 bg-gradient-to-br from-amber-600 to-orange-600 rounded-3xl p-4 text-white relative overflow-hidden group hover:scale-[1.02] transition-transform duration-300">
          <div class="absolute inset-0 opacity-20">
            <div class="grid grid-cols-3 gap-2 h-full">
              <div class="flex items-center justify-center">
                <Code class="w-5 h-5" />
              </div>
              <div class="flex items-center justify-center">
                <Star class="w-5 h-5" />
              </div>
              <div class="flex items-center justify-center">
                <Trophy class="w-5 h-5" />
              </div>
              <div class="flex items-center justify-center">
                <Users class="w-5 h-5" />
              </div>
              <div class="flex items-center justify-center">
                <Globe class="w-5 h-5" />
              </div>
              <div class="flex items-center justify-center">
                <ExternalLink class="w-5 h-5" />
              </div>
            </div>
          </div>
          <div class="relative z-10 h-full flex flex-col justify-between">
            <div class="text-xs text-orange-200 mb-2" data-text="skillsText">Skills & Technologies</div>
            <div class="grid grid-cols-2 gap-1 text-xs">
              <span>React</span>
              <span>Next.js</span>
              <span>TypeScript</span>
              <span>Tailwind</span>
            </div>
          </div>
        </div>

        <!-- 12 - Experience -->
        <div class="row-span-2 col-start-3 row-start-7 bg-gradient-to-br from-blue-500 to-blue-600 rounded-3xl p-4 text-white group hover:scale-[1.02] transition-transform duration-300">
          <div class="h-full flex flex-col justify-center items-center text-center">
            <div class="text-3xl font-bold mb-1">+6m</div>
            <div class="text-blue-100 text-xs font-medium" data-text="experienceText">MONTHS EXPERIENCE</div>
          </div>
        </div>

        <!-- 13 - Twitter -->
        <div class="row-span-2 col-start-4 row-start-7 bg-gradient-to-br from-slate-800 to-slate-900 rounded-3xl p-4 text-white flex items-center justify-center group hover:scale-[1.02] transition-transform duration-300 cursor-pointer">
          <Twitter class="w-10 h-10 group-hover:scale-110 transition-transform duration-300" />
        </div>

        <!-- 14 - Currently Working -->
        <div class="col-span-2 row-span-2 row-start-9 bg-gradient-to-br from-emerald-600 to-emerald-700 rounded-3xl p-4 text-white relative overflow-hidden group hover:scale-[1.02] transition-transform duration-300">
          <div class="absolute top-3 right-3">
            <div class="w-3 h-3 bg-green-400 rounded-full animate-pulse"></div>
          </div>
          <div class="h-full flex flex-col justify-between">
            <div>
              <h3 class="text-base font-semibold mb-2" data-text="currentlyText">Currently focused</h3>
              <p class="text-emerald-100 text-sm" data-text="workText">
                Working remotely on amazing projects with talented teams.
              </p>
            </div>
            <div class="flex items-center gap-2 text-emerald-200">
              <Users class="w-4 h-4" />
              <span class="text-xs">Remote Team</span>
            </div>
          </div>
        </div>

        <!-- 15 - Discord Status -->
        <DiscordStatus />

        <!-- 16 - Contact Level -->
        <div class="row-span-2 col-start-4 row-start-9  bg-slate-700/90 backdrop-blur-sm rounded-3xl p-4 text-white flex items-center justify-center group hover:scale-[1.02] transition-transform duration-300 cursor-pointer border border-slate-600/50">
          <div class="text-center">
            <Mail class="w-8 h-8 mx-auto mb-2 group-hover:scale-110 transition-transform duration-300" />
            <div class="text-xs text-slate-400" data-text="offlineText">Offline</div>
          </div>
        </div>

        <!-- 17 - X -->
        <div class="row-span-2 row-start-11 bg-gradient-to-br from-slate-800 to-slate-900 rounded-3xl p-4 text-white flex items-center justify-center group hover:scale-[1.02] transition-transform duration-300 cursor-pointer">
          <Twitter class="w-10 h-10 group-hover:scale-110 transition-transform duration-300" />
        </div>

        <!-- 18 - Time -->
        <div class="col-span-2 row-span-2 row-start-11 bg-gradient-to-br from-indigo-600 to-purple-600 rounded-3xl p-4 text-white relative overflow-hidden group hover:scale-[1.02] transition-transform duration-300">
          <div class="absolute top-3 right-3">
            <Sun class="w-6 h-6 text-yellow-400" />
          </div>
          <div class="h-full flex flex-col justify-between">
            <div class="text-2xl font-bold">25°</div>
            <div>
              <div class="text-sm">Scattered Clouds</div>
              <div class="text-xs text-indigo-200">San José, CR</div>
            </div>
          </div>
        </div>

        <!-- 19 - Additional Info -->
        <div class="row-span-2 col-start-4 row-start-11 bg-gradient-to-br from-violet-600 to-violet-700 rounded-3xl p-4 text-white group hover:scale-[1.02] transition-transform duration-300">
          <div class="h-full flex flex-col justify-center items-center text-center">
            <div class="text-2xl font-bold mb-1">B2</div>
            <div class="text-teal-100 text-xs" data-text="contactText">Let's work together</div>
          </div>
        </div>

      </div>

      <!-- Footer -->
      <div class="mt-8 text-center">
        <p class="text-slate-400 text-sm">
          Built with Astro & Tailwind CSS • 2025
        </p>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { initLanguageSwitcher } from '../scripts/languageSwitcher.ts';
  import { initDiscordStatus } from '../scripts/discordStatus.ts';
  import { initAgeDisplay } from '../scripts/utils.ts';

  // Initialize all functionality when page loads
  window.addEventListener("DOMContentLoaded", () => {
    initLanguageSwitcher();
    initDiscordStatus();
    initAgeDisplay();
  });
</script>